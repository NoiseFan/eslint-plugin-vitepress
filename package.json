{
  "name": "eslint-plugin-docs-style",
  "type": "module",
  "version": "0.0.0",
  "packageManager": "pnpm@10.21.0",
  "description": "ESLint plugin for enforcing style rules in Markdown-based documentation",
  "author": "noisefan <noisefan@163.com>",
  "license": "MIT",
  "homepage": "https://github.com/NoiseFan/eslint-plugin-docs-style#readme",
  "repository": {
    "type": "git",
    "url": "git+github.com:NoiseFan/eslint-plugin-docs-style.git"
  },
  "bugs": {
    "url": "https://github.com/NoiseFan/eslint-plugin-docs-style/issues"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "pnpm run lint --fix",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "test:cov": "vitest --coverage",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build",
    "prepare": "simple-git-hooks"
  },
  "peerDependencies": {
    "@eslint/markdown": "^7.5.1",
    "eslint": "^9.0.0 || ^10.0.0"
  },
  "dependencies": {
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.2.0",
    "@eslint/markdown": "^7.5.1",
    "@types/mdast": "^4.0.4",
    "@types/node": "^24.10.1",
    "@typescript-eslint/utils": "^8.46.4",
    "@vitest/coverage-v8": "^4.1.5",
    "bumpp": "^10.3.1",
    "eslint": "9.39.1",
    "eslint-plugin-format": "^1.0.2",
    "eslint-vitest-rule-tester": "^3.0.0",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1",
    "tinyglobby": "^0.2.16",
    "tsdown": "^0.16.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.9"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,md,yml,yaml,json}": [
      "eslint --cache --fix"
    ]
  }
}
