{
  "name": "eslint-plugin-md-style",
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@10.21.0",
  "description": "ESLint plugin for enforcing style rules in Markdown-based documentation",
  "author": "noisefan <noisefan@163.com>",
  "license": "MIT",
  "homepage": "https://github.com/NoiseFan/eslint-plugin-md-style#readme",
  "repository": {
    "type": "git",
    "url": "git+github.com:NoiseFan/eslint-plugin-md-style.git"
  },
  "bugs": {
    "url": "https://github.com/NoiseFan/eslint-plugin-md-style/issues"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "pnpm run lint --fix",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "test:cov": "vitest --coverage",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build",
    "prepare": "simple-git-hooks"
  },
  "peerDependencies": {
    "@antfu/eslint-config": "^7.5.0",
    "@eslint/markdown": "^7.5.1",
    "eslint": "^9.30.0 || ^10.0.0"
  },
  "peerDependenciesMeta": {
    "@antfu/eslint-config": {
      "optional": true
    }
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@eslint/markdown": "^8.0.1",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.7.0",
    "@typescript-eslint/utils": "^8.59.3",
    "@vitest/coverage-v8": "^4.1.6",
    "bumpp": "^11.1.0",
    "eslint": "10.3.0",
    "eslint-factory": "^0.1.2",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-md-style": "^0.1.0",
    "eslint-vitest-rule-tester": "^3.1.0",
    "lint-staged": "^17.0.4",
    "simple-git-hooks": "^2.13.1",
    "tinyglobby": "^0.2.16",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,md,yml,yaml,json}": [
      "eslint --cache --fix"
    ]
  }
}
